# aistudio-api 配置
# 复制此文件为 .env 并修改

# ========== 服务 ==========
AISTUDIO_PORT=8090

# ========== 浏览器 ==========
# 浏览器后端：camoufox 或 chromium
AISTUDIO_BROWSER=chromium
# 浏览器调试端口（仅 Camoufox 后端使用）
AISTUDIO_BROWSER_PORT=9222
# 浏览器是否无头模式（1=无头，0=有头）
AISTUDIO_BROWSER_HEADLESS=1
# Chromium channel（可选，例如 chrome、msedge）
AISTUDIO_BROWSER_CHANNEL=
# Chromium 可执行文件路径（可选）
AISTUDIO_BROWSER_EXECUTABLE=
# 浏览器启动解释器（仅 Camoufox 后端需要）
AISTUDIO_BROWSER_PYTHON=

# ========== 网络 / 认证 ==========
# 代理地址
AISTUDIO_PROXY=
# API 鉴权，支持单个 key 或逗号分隔多个 key
AISTUDIO_API_KEY=
# AISTUDIO_API_KEYS=key-1,key-2
# 认证文件路径（可选，留空自动搜索 data/ 目录）
AISTUDIO_AUTH_FILE=
# 临时文件目录
AISTUDIO_TMP_DIR=/tmp

# ========== 模型 ==========
AISTUDIO_DEFAULT_TEXT_MODEL=gemma-4-31b-it
AISTUDIO_DEFAULT_IMAGE_MODEL=gemini-3.1-flash-image-preview

# ========== 超时 / 缓存 ==========
AISTUDIO_TIMEOUT_REPLAY=120
AISTUDIO_TIMEOUT_STREAM=120
AISTUDIO_TIMEOUT_CAPTURE=30
AISTUDIO_SNAPSHOT_CACHE_TTL=3600
AISTUDIO_SNAPSHOT_CACHE_MAX=100


# ========== OpenAI 兼容 API 默认参数 ==========
# 这些默认值只作用于 /v1/chat/completions。客户端请求显式传值时，以请求值为准。
# 留空表示保持原始行为，不主动覆盖 AI Studio/模型默认值。
AISTUDIO_OPENAI_DEFAULT_TEMPERATURE=
AISTUDIO_OPENAI_DEFAULT_TOP_P=
AISTUDIO_OPENAI_DEFAULT_TOP_K=
# 和官方浏览器最大输出 Token 保持一致；留空则 API 请求不主动设置 max_tokens。
AISTUDIO_OPENAI_DEFAULT_MAX_TOKENS=65536
# 可选值：off、low、medium、high、minimal。留空表示不覆盖。
AISTUDIO_OPENAI_DEFAULT_THINKING=
# 留空=沿用模型默认工具；1=默认开启 Google Search；0=关闭默认 Google Search。
# Hermes agent 显式带 tools 时，不会因为此默认值自动混入 Google Search。
AISTUDIO_OPENAI_DEFAULT_GOOGLE_SEARCH=
# 1=将安全过滤阈值调到最宽松；0=保持默认。
AISTUDIO_OPENAI_DEFAULT_SAFETY_OFF=0
# 不完整最终文本自动修复最多重试次数；默认 5，运行时限制在 1～10。
AISTUDIO_OPENAI_REPAIR_MAX_ATTEMPTS=5

# ========== 调试 ==========
AISTUDIO_DUMP_RAW_RESPONSE=0
AISTUDIO_DUMP_RAW_RESPONSE_DIR=/tmp

# ========== 账号轮询配置 ==========
# 账号存储目录（留空则使用默认 data/accounts）
AISTUDIO_ACCOUNTS_DIR=
# 登录浏览器调试端口（仅 Camoufox 后端使用）
AISTUDIO_LOGIN_BROWSER_PORT=9223
# 轮询模式：round_robin、lru、least_rl
AISTUDIO_ACCOUNT_ROTATION_MODE=round_robin
# 账号冷却时间（秒）
AISTUDIO_ACCOUNT_COOLDOWN_SECONDS=60
# 禁止参与自动轮询的账号 ID，多个账号用英文逗号分隔；留空表示不禁用
AISTUDIO_DISABLED_ACCOUNTS=
# 单账号最大重试次数
AISTUDIO_ACCOUNT_MAX_RETRIES=3
# 最大并发数
AISTUDIO_MAX_CONCURRENCY=3
